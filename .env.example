DEBUG=True
DJANGO_SECRET_KEY=django-insecure-change-me
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=

LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# Google AI Studio / Gemini API key. Either name works.
GOOGLE_API_KEY=your-google-ai-studio-api-key
GEMINI_API_KEY=
GEMMA_MODEL=gemma-4-26b-a4b-it

# Public HTTPS origin for LINE webhook and optional Flex card image previews.
# Local ngrok example: https://xxxx.ngrok-free.app
# Zeabur example: https://your-service.zeabur.app
PUBLIC_BASE_URL=

# Local docker compose defaults.
POSTGRES_DB=line_cards
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Zeabur usually provides DATABASE_URL from the PostgreSQL service.
DATABASE_URL=

# Set True only for quick local tests without PostgreSQL.
USE_SQLITE=False
